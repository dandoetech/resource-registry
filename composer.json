{
  "name": "dandoetech/package-skeleton",
  "description": "A modern PHP package skeleton with CI, QA, and quality reporting (Codacy + SonarCloud).",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Danilo Doelle",
      "email": "oss@dandoe.tech"
    }
  ],
  "require": {
    "php": "^8.2 || ^8.3 || ^8.4"
  },
  "autoload": {
    "psr-4": {
      "DanDoeTech\\PackageSkeleton\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DanDoeTech\\PackageSkeleton\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.3",
    "friendsofphp/php-cs-fixer": "^3.64",
    "phpstan/phpstan": "^1.11"
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-text --coverage-clover=coverage/clover.xml",
    "cs:fix": "php-cs-fixer fix --allow-risky=yes",
    "cs:check": "php-cs-fixer fix --allow-risky=yes --dry-run",
    "stan": "phpstan analyse --memory-limit=1G",
    "qa": [
      "@cs:check",
      "@stan",
      "@test"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
